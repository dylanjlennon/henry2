{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/slack/command.ts": {
      "maxDuration": 300,
      "memory": 2048
    },
    "api/slack/events.ts": {
      "maxDuration": 300,
      "memory": 2048
    },
    "api/runs/index.ts": {
      "maxDuration": 30,
      "memory": 512
    },
    "api/runs/[id].ts": {
      "maxDuration": 30,
      "memory": 512
    },
    "api/fetchers/[id].ts": {
      "maxDuration": 300,
      "memory": 2048
    },
    "api/artifact/[id].ts": {
      "maxDuration": 30,
      "memory": 512
    },
    "api/web/search.ts": {
      "maxDuration": 300,
      "memory": 1024
    },
    "api/web/status/[id].ts": {
      "maxDuration": 30,
      "memory": 512
    },
    "api/web/history.ts": {
      "maxDuration": 30,
      "memory": 512
    },
    "api/web/config.ts": {
      "maxDuration": 10,
      "memory": 256
    }
  }
}
